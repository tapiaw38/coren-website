---
import { Icon } from 'astro-icon/components';
const isHome = Astro.url.pathname === '/';
---

<header class="fixed top-0 left-0 right-0 z-50 bg-ctp-base/90 backdrop-blur-xl border-b border-white/[0.06]">
  <nav class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
    <a href="/" class="flex items-center gap-2 text-ctp-text font-bold text-lg tracking-tight">
      <img src="/coral-icon.png" alt="coren" class="w-6 h-6 object-contain" />
      <span class="text-coren-accent font-bold">coren</span>
    </a>

    {isHome && (
      <div class="hidden md:flex items-center gap-8 text-sm text-ctp-subtext1">
        <a href="#features" class="hover:text-ctp-text transition-colors">Features</a>
        <a href="#modes" class="hover:text-ctp-text transition-colors">Modes</a>
        <a href="#install" class="hover:text-ctp-text transition-colors">Install</a>
        <a href="#pricing" class="hover:text-ctp-text transition-colors">Pricing</a>
      </div>
    )}

    <div class="flex items-center gap-2">
      <a
        href="/docs"
        class="flex items-center gap-2 text-sm border border-white/20 px-4 py-2 rounded-lg hover:border-coren-accent/40 hover:bg-white/[0.04] transition-all duration-200"
      >
        <Icon name="lucide:book-open" class="w-4 h-4" />
        Docs
      </a>
    </div>
  </nav>
</header>
