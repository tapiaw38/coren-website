---
import { Icon } from 'astro-icon/components';
---

<footer class="border-t border-white/[0.06] py-12 px-6">
  <div class="max-w-6xl mx-auto flex flex-col md:flex-row items-center justify-between gap-6">
    <div class="flex items-center gap-2 font-bold text-lg">
      <span class="text-corix-accent">corix</span>
    </div>
    <p class="text-ctp-overlay0 text-sm">
      Built with ❤️ and Catppuccin Mocha
    </p>
    <div class="flex items-center gap-4">
      <a href="https://github.com/oceanstack/gterm" class="text-ctp-overlay0 hover:text-ctp-text transition-colors">
        <Icon name="lucide:github" class="w-5 h-5" />
      </a>
    </div>
  </div>
</footer>
