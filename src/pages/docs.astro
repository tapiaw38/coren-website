        <!-- ── FAQ ──────────────────────────────────────────────── -->
        <section id="faq" class="doc-section mb-20">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-8 rounded-lg bg-corix-accent/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:help-circle" class="w-4 h-4 text-corix-accent" />
            </div>
            <h1 class="text-3xl font-bold text-ctp-text">FAQ</h1>
          </div>

          <div class="space-y-4">
            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">Does corix send my terminal output to a remote server?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Only when an AI mode is active (Watch, Execute, or Debug) and output is captured. The data flows from corix → corix-proxy (local) → your chosen AI provider. corix itself never communicates with any Oceanstack servers after the initial license check. If you use Ollama, output never leaves your machine.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">Is my API key stored securely?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Yes. Your API key is stored by corix-proxy on your local machine (in <code class="text-corix-accent">~/.config/corix-proxy/</code>) and is never transmitted to Oceanstack. It is only sent directly to your chosen AI provider when making requests.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">Can I use corix without an internet connection?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Partially. corix itself works fully offline as a terminal emulator. AI features require a connection to your provider. If you configure Ollama as your provider and run it locally, all AI features work offline.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">How is corix different from just using ChatGPT in a browser tab?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                corix is aware of your actual terminal context — current directory, git branch, command output, exit codes. Watch and Debug modes react to your shell automatically without you having to copy-paste anything. You stay in the terminal; the AI comes to you.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">Which AI providers are supported?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Currently: <strong class="text-ctp-text">DeepSeek</strong> (recommended), <strong class="text-ctp-text">OpenAI</strong>, and <strong class="text-ctp-text">Ollama</strong> (local). More providers — Anthropic, Mistral, Groq — are planned for upcoming releases.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">Can multiple team members share a Team subscription?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-colors" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Yes. The Team plan is priced per seat ($20/user/month) and each seat receives its own license key. An admin dashboard for managing seats is on the roadmap.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">What terminals / OSes are supported?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                corix runs on Linux and macOS (arm64 and amd64). It requires a terminal with 256-color and mouse reporting support. Tested with kitty, alacritty, WezTerm, and iTerm2. Windows support (via WSL) is planned.
              </div>
            </details>

            <details class="faq-item group">
              <summary class="flex items-center justify-between gap-4 cursor-pointer list-none py-4 px-5 rounded-lg bg-ctp-surface0/40 hover:bg-ctp-surface0/70 transition-colors">
                <span class="text-ctp-text font-medium">How do I report a bug or request a feature?</span>
                <Icon name="lucide:chevron-down" class="w-4 h-4 text-ctp-overlay0 shrink-0 group-open:rotate-180 transition-transform" />
              </summary>
              <div class="px-5 pt-3 pb-5 text-ctp-subtext1 leading-relaxed text-sm">
                Open an issue on the GitHub repository or join the Discord community. For billing and license issues, email <code class="text-corix-accent">support@corix.dev</code>.
              </div>
            </details>
          </div>
        </section>

      </div>
    </div>
  </div>
</Layout>

<style>
  /* Sidebar active link */
  .sidebar-link.active {
    color: theme('colors.corix.accent');
    background-color: theme('colors.corix.accent / 0.08');
  }

  /* Shortcut table rows */
  .shortcut-table {
    @apply border border-white/[0.06] rounded-xl overflow-hidden;
  }
  .shortcut-row {
    @apply flex items-center gap-4 px-4 py-3 border-b border-white/[0.04] last:border-0 flex-wrap;
  }
  .shortcut-row:hover {
    @apply bg-white/[0.02];
  }

  /* Key badges */
  .key {
    @apply inline-flex items-center justify-center px-1.5 py-0.5 rounded text-xs font-mono font-medium
           bg-ctp-surface0 text-ctp-subtext1 border border-white/[0.1] shadow-sm min-w-[1.5rem];
  }
  .key-sep {
    @apply text-ctp-overlay0 text-xs;
  }

  /* FAQ */
  details summary::-webkit-details-marker { display: none; }
  details[open] {
    @apply bg-ctp-surface0/40 rounded-lg border border-white/[0.06];
  }
</style>

<script>
  // ── Active sidebar highlighting via IntersectionObserver ──
  const sections = document.querySelectorAll<HTMLElement>('.doc-section, [id]');
  const links = document.querySelectorAll<HTMLAnchorElement>('.sidebar-link');

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          const id = entry.target.id;
          links.forEach((link) => {
            const href = link.getAttribute('href');
            if (href === `#${id}`) {
              link.classList.add('active');
            } else {
              link.classList.remove('active');
            }
          });
        }
      });
    },
    {
      rootMargin: '-20% 0% -70% 0%',
      threshold: 0,
    }
  );

  // Observe all heading anchors
  document.querySelectorAll('section[id], h2[id]').forEach((el) => {
    observer.observe(el);
  });

  // Also observe individual anchor targets
  document.querySelectorAll('[id]').forEach((el) => {
    observer.observe(el);
  });

  // ── Smooth scroll for sidebar links ──
  links.forEach((link) => {
    link.addEventListener('click', (e) => {
      const href = link.getAttribute('href');
      if (href?.startsWith('#')) {
        e.preventDefault();
        const target = document.querySelector(href);
        if (target) {
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // Update active state immediately on click
          links.forEach((l) => l.classList.remove('active'));
          link.classList.add('active');
        }
      }
    });
  });

  // ── Mobile: sidebar toggle via Navbar ──
  // (sidebar is hidden on mobile; could wire a hamburger toggle here)
</script>
