---
import Layout from '../layouts/Layout.astro';
import { Icon } from 'astro-icon/components';
---

<Layout
  title="Documentation — corix"
  description="corix documentation: installation, configuration, AI modes, keyboard shortcuts, and FAQ."
>
  <div class="min-h-screen flex">
    <!-- ── SIDEBAR ────────────────────────────────────────────── -->
    <aside id="sidebar" class="hidden lg:flex flex-col w-64 xl:w-72 shrink-0 border-r border-white/[0.06] sticky top-16 h-[calc(100vh-4rem)] overflow-y-auto py-8 px-5 bg-ctp-base">
      <p class="text-xs font-bold uppercase tracking-widest text-ctp-overlay0 mb-4 px-2">Documentation</p>
      <nav class="flex flex-col gap-0.5" id="sidebar-nav">
        <!-- Get Started -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="get-started">
            <Icon name="lucide:rocket" class="w-3.5 h-3.5 opacity-60" />
            Get Started
          </button>
          <div class="sidebar-children pl-5 flex flex-col gap-0.5 mt-0.5">
            <a href="#what-is-corix" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">What is corix?</a>
            <a href="#requirements" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Requirements</a>
          </div>
        </div>

        <!-- Installation -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="installation">
            <Icon name="lucide:download" class="w-3.5 h-3.5 opacity-60" />
            Installation
          </button>
          <div class="sidebar-children pl-5 flex flex-col gap-0.5 mt-0.5">
            <a href="#install-corix" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Install corix</a>
            <a href="#install-proxy" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Setup corix-proxy</a>
            <a href="#providers" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">AI Providers</a>
          </div>
        </div>

        <!-- Configuration -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="configuration">
            <Icon name="lucide:settings" class="w-3.5 h-3.5 opacity-60" />
            Configuration
          </button>
          <div class="sidebar-children pl-5 flex flex-col gap-0.5 mt-0.5">
            <a href="#config-file" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Config file</a>
            <a href="#config-options" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">All options</a>
          </div>
        </div>

        <!-- AI Modes -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="ai-modes">
            <Icon name="lucide:brain" class="w-3.5 h-3.5 opacity-60" />
            AI Modes
          </button>
          <div class="sidebar-children pl-5 flex flex-col gap-0.5 mt-0.5">
            <a href="#mode-default" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Default</a>
            <a href="#mode-watch" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Watch</a>
            <a href="#mode-execute" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Execute</a>
            <a href="#mode-debug" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Debug</a>
          </div>
        </div>

        <!-- Keyboard Shortcuts -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="keyboard-shortcuts">
            <Icon name="lucide:keyboard" class="w-3.5 h-3.5 opacity-60" />
            Keyboard Shortcuts
          </button>
          <div class="sidebar-children pl-5 flex flex-col gap-0.5 mt-0.5">
            <a href="#shortcuts-global" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Global</a>
            <a href="#shortcuts-ai" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">AI Panel</a>
            <a href="#shortcuts-terminal" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Terminal</a>
            <a href="#shortcuts-panes" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Panes</a>
            <a href="#shortcuts-commands" class="sidebar-link text-sm text-ctp-overlay0 hover:text-ctp-text px-2 py-1 rounded transition-colors">Slash Commands</a>
          </div>
        </div>

        <!-- FAQ -->
        <div class="mb-2">
          <button class="sidebar-group w-full flex items-center gap-2 px-2 py-1.5 text-sm font-semibold text-ctp-subtext1 hover:text-ctp-text transition-colors rounded" data-section="faq">
            <Icon name="lucide:help-circle" class="w-3.5 h-3.5 opacity-60" />
            FAQ
          </button>
        </div>
      </nav>

      <!-- Version badge -->
      <div class="mt-auto pt-8">
        <div class="px-2 py-2 rounded-lg bg-ctp-surface0/50 text-xs text-ctp-overlay0 flex items-center gap-2">
          <span class="w-1.5 h-1.5 rounded-full bg-ctp-green animate-pulse-slow"></span>
          corix v0.1 — early access
        </div>
      </div>
    </aside>

    <!-- ── MAIN CONTENT ────────────────────────────────────────── -->
    <div class="flex-1 min-w-0">
      <div class="max-w-3xl mx-auto px-6 lg:px-10 py-12 pb-32">

        <!-- ── GET STARTED ──────────────────────────────────────── -->
        <section id="get-started" class="doc-section mb-20">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-8 rounded-lg bg-corix-accent/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:rocket" class="w-4 h-4 text-corix-accent" />
            </div>
            <h1 class="text-3xl font-bold text-ctp-text">Get Started</h1>
          </div>

          <p class="text-ctp-subtext1 text-lg leading-relaxed mb-10">
            corix is an AI-native terminal emulator built with Go. It embeds a live AI panel directly into your terminal session — no browser, no extra windows, just your shell with intelligence baked in.
          </p>

          <h2 id="what-is-corix" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">What is corix?</h2>
          <p class="text-ctp-subtext1 leading-relaxed mb-6">
            corix wraps your shell in a full vt10x-compatible terminal emulator rendered in the TUI. An AI panel can appear at any edge (top, bottom, left, or right) and runs in four distinct modes: <strong class="text-ctp-text">Default</strong> for free-form Q&amp;A, <strong class="text-ctp-text">Watch</strong> for passive monitoring, <strong class="text-ctp-text">Execute</strong> for AI-driven command suggestions, and <strong class="text-ctp-text">Debug</strong> for automatic error analysis.
          </p>

          <div class="grid sm:grid-cols-3 gap-4 mb-10">
            <div class="card p-4">
              <div class="text-corix-accent font-mono font-bold text-2xl mb-1">4</div>
              <div class="text-ctp-subtext1 text-sm">AI modes</div>
            </div>
            <div class="card p-4">
              <div class="text-corix-accent font-mono font-bold text-2xl mb-1">0ms</div>
              <div class="text-ctp-subtext1 text-sm">startup overhead</div>
            </div>
            <div class="card p-4">
              <div class="text-corix-accent font-mono font-bold text-2xl mb-1">BYOK</div>
              <div class="text-ctp-subtext1 text-sm">bring your own key</div>
            </div>
          </div>

          <h2 id="requirements" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">Requirements</h2>
          <ul class="space-y-2 text-ctp-subtext1 mb-6">
            <li class="flex items-start gap-2"><span class="text-corix-accent mt-1">›</span> Linux or macOS (arm64 / amd64)</li>
            <li class="flex items-start gap-2"><span class="text-corix-accent mt-1">›</span> A terminal that supports 256-color and mouse reporting (kitty, alacritty, wezterm, iTerm2, …)</li>
            <li class="flex items-start gap-2"><span class="text-corix-accent mt-1">›</span> An API key for at least one AI provider (DeepSeek, OpenAI, or a local Ollama instance)</li>
            <li class="flex items-start gap-2"><span class="text-corix-accent mt-1">›</span> An active corix subscription (Starter · Pro · Team)</li>
          </ul>
        </section>

        <hr class="border-white/[0.06] mb-20" />

        <!-- ── INSTALLATION ──────────────────────────────────────── -->
        <section id="installation" class="doc-section mb-20">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-8 rounded-lg bg-corix-accent/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:download" class="w-4 h-4 text-corix-accent" />
            </div>
            <h1 class="text-3xl font-bold text-ctp-text">Installation</h1>
          </div>

          <h2 id="install-corix" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">Install corix</h2>
          <p class="text-ctp-subtext1 leading-relaxed mb-4">
            The quickest way to install corix is with the one-liner below. The script detects your OS and architecture, downloads the correct binary, and places it in <code class="text-corix-accent">/usr/local/bin</code>.
          </p>

          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
              <span class="ml-auto text-xs text-ctp-overlay0">bash</span>
            </div>
            <div class="p-4 font-mono text-sm">
              <span class="text-ctp-green">$</span> <span class="text-ctp-text">curl -fsSL https://corix.dev/install.sh | sh</span>
            </div>
          </div>

          <p class="text-ctp-subtext1 leading-relaxed mb-4">After installation, verify the binary is accessible:</p>

          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
            </div>
            <div class="p-4 font-mono text-sm space-y-1">
              <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix --version</span></div>
              <div class="text-ctp-overlay0">corix v0.1.0 (linux/amd64)</div>
            </div>
          </div>

          <div class="card p-4 mb-10 flex gap-3">
            <Icon name="lucide:info" class="w-4 h-4 text-ctp-blue shrink-0 mt-0.5" />
            <p class="text-ctp-subtext1 text-sm leading-relaxed">
              To install manually, download the release archive from the GitHub releases page, extract the <code class="text-corix-accent">corix</code> binary, and move it to a directory in your <code class="text-corix-accent">$PATH</code>.
            </p>
          </div>

          <h2 id="install-proxy" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">Setup corix-proxy</h2>
          <p class="text-ctp-subtext1 leading-relaxed mb-4">
            <strong class="text-ctp-text">corix-proxy</strong> is a lightweight local server that holds your API keys and license, acting as the bridge between corix and your AI provider. It runs as a background daemon and is required for the AI features to work.
          </p>

          <div class="terminal-window mb-6">
            <div class="terminal-chrome">
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
              <span class="ml-auto text-xs text-ctp-overlay0">bash</span>
            </div>
            <div class="p-4 font-mono text-sm space-y-1">
              <div class="text-ctp-overlay0"># Install corix-proxy</div>
              <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">curl -fsSL https://corix.dev/install-proxy.sh | sh</span></div>
              <div class="mt-2 text-ctp-overlay0"># Initialize with your license key</div>
              <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy init --license YOUR_LICENSE_KEY</span></div>
              <div class="text-ctp-green">✓ License validated — proxy running on :7432</div>
            </div>
          </div>

          <p class="text-ctp-subtext1 leading-relaxed mb-4">
            The proxy registers itself as a systemd/launchd service automatically. You can also start it manually:
          </p>

          <div class="terminal-window mb-10">
            <div class="terminal-chrome">
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
            </div>
            <div class="p-4 font-mono text-sm space-y-1">
              <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy start</span></div>
              <div class="text-ctp-overlay0">Proxy listening on 127.0.0.1:7432</div>
              <div class="mt-2"><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy status</span></div>
              <div class="text-ctp-green">● running  pid 84312  port 7432  provider deepseek</div>
            </div>
          </div>

          <h2 id="providers" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">AI Providers</h2>
          <p class="text-ctp-subtext1 leading-relaxed mb-6">
            corix supports multiple AI backends. Configure your preferred provider by adding your API key to the proxy:
          </p>

          <div class="space-y-4 mb-8">
            <!-- DeepSeek -->
            <div class="card p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-6 h-6 rounded bg-ctp-blue/20 flex items-center justify-center">
                  <span class="text-ctp-blue text-xs font-bold">DS</span>
                </div>
                <h3 class="font-semibold text-ctp-text">DeepSeek <span class="text-xs text-ctp-green ml-2 bg-ctp-green/10 px-1.5 py-0.5 rounded">recommended</span></h3>
              </div>
              <div class="terminal-window">
                <div class="p-3 font-mono text-sm space-y-1">
                  <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy set-provider deepseek --key sk-...</span></div>
                </div>
              </div>
              <p class="text-ctp-overlay0 text-xs mt-2">Best cost-to-quality ratio. Uses <code>deepseek-chat</code> by default.</p>
            </div>

            <!-- OpenAI -->
            <div class="card p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-6 h-6 rounded bg-ctp-green/20 flex items-center justify-center">
                  <span class="text-ctp-green text-xs font-bold">OA</span>
                </div>
                <h3 class="font-semibold text-ctp-text">OpenAI</h3>
              </div>
              <div class="terminal-window">
                <div class="p-3 font-mono text-sm space-y-1">
                  <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy set-provider openai --key sk-...</span></div>
                </div>
              </div>
              <p class="text-ctp-overlay0 text-xs mt-2">Uses <code>gpt-4o-mini</code> by default. Pass <code>--model gpt-4o</code> for full GPT-4o.</p>
            </div>

            <!-- Ollama -->
            <div class="card p-5">
              <div class="flex items-center gap-3 mb-3">
                <div class="w-6 h-6 rounded bg-ctp-peach/20 flex items-center justify-center">
                  <span class="text-ctp-peach text-xs font-bold">OL</span>
                </div>
                <h3 class="font-semibold text-ctp-text">Ollama <span class="text-xs text-ctp-subtext1 ml-2">local</span></h3>
              </div>
              <div class="terminal-window">
                <div class="p-3 font-mono text-sm space-y-1">
                  <div><span class="text-ctp-green">$</span> <span class="text-ctp-text">corix-proxy set-provider ollama --url http://localhost:11434 --model llama3</span></div>
                </div>
              </div>
              <p class="text-ctp-overlay0 text-xs mt-2">No API key required. Requires a running Ollama instance.</p>
            </div>
          </div>
        </section>

        <hr class="border-white/[0.06] mb-20" />

        <!-- ── CONFIGURATION ─────────────────────────────────────── -->
        <section id="configuration" class="doc-section mb-20">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-8 rounded-lg bg-corix-accent/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:settings" class="w-4 h-4 text-corix-accent" />
            </div>
            <h1 class="text-3xl font-bold text-ctp-text">Configuration</h1>
          </div>

          <h2 id="config-file" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">Config file</h2>
          <p class="text-ctp-subtext1 leading-relaxed mb-4">
            corix reads its configuration from <code class="text-corix-accent">~/.config/corix/config.yaml</code>. The file is created automatically on first run with sensible defaults.
          </p>

          <div class="terminal-window mb-10">
            <div class="terminal-chrome">
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
              <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
              <span class="ml-auto text-xs text-ctp-overlay0">~/.config/corix/config.yaml</span>
            </div>
            <div class="p-4 font-mono text-sm space-y-1 leading-relaxed">
              <div class="text-ctp-overlay0"># corix configuration</div>
              <div><span class="text-ctp-blue">shell</span><span class="text-ctp-text">: </span><span class="text-ctp-green">""</span><span class="text-ctp-overlay0">             # default: $SHELL</span></div>
              <div><span class="text-ctp-blue">ai_panel_pos</span><span class="text-ctp-text">: </span><span class="text-ctp-green">"bottom"</span><span class="text-ctp-overlay0">      # bottom | top | left | right</span></div>
              <div><span class="text-ctp-blue">ai_panel_open</span><span class="text-ctp-text">: </span><span class="text-ctp-peach">false</span><span class="text-ctp-overlay0">         # open AI panel on startup</span></div>
              <div><span class="text-ctp-blue">ai_mode</span><span class="text-ctp-text">: </span><span class="text-ctp-green">"default"</span><span class="text-ctp-overlay0">      # default | watch | execute | debug</span></div>
              <div><span class="text-ctp-blue">proxy_url</span><span class="text-ctp-text">: </span><span class="text-ctp-green">"http://127.0.0.1:7432"</span></div>
              <div><span class="text-ctp-blue">assistant</span><span class="text-ctp-text">: </span><span class="text-ctp-green">""</span><span class="text-ctp-overlay0">            # optional: load a named assistant</span></div>
              <div><span class="text-ctp-blue">conv_id</span><span class="text-ctp-text">: </span><span class="text-ctp-green">""</span><span class="text-ctp-overlay0">              # optional: resume a conversation</span></div>
            </div>
          </div>

          <h2 id="config-options" class="text-xl font-semibold text-ctp-text mb-4 scroll-mt-24">All options</h2>

          <div class="overflow-x-auto mb-10">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/[0.08]">
                  <th class="text-left py-3 px-4 text-ctp-subtext1 font-semibold">Key</th>
                  <th class="text-left py-3 px-4 text-ctp-subtext1 font-semibold">Default</th>
                  <th class="text-left py-3 px-4 text-ctp-subtext1 font-semibold">Description</th>
                </tr>
              </thead>
              <tbody class="text-ctp-subtext1">
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">shell</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">$SHELL</td>
                  <td class="py-3 px-4">Shell binary to launch (e.g. <code>/bin/zsh</code>)</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">ai_panel_pos</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">bottom</td>
                  <td class="py-3 px-4">Default position of the AI panel when opened</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">ai_panel_open</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">false</td>
                  <td class="py-3 px-4">Open the AI panel automatically on startup</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">ai_mode</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">default</td>
                  <td class="py-3 px-4">Starting AI mode: default · watch · execute · debug</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">proxy_url</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">localhost:7432</td>
                  <td class="py-3 px-4">URL of your corix-proxy instance</td>
                </tr>
                <tr class="border-b border-white/[0.04] hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">assistant</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">—</td>
                  <td class="py-3 px-4">Load a saved assistant persona by name</td>
                </tr>
                <tr class="hover:bg-white/[0.02] transition-colors">
                  <td class="py-3 px-4"><code class="text-corix-accent">conv_id</code></td>
                  <td class="py-3 px-4 text-ctp-overlay0">—</td>
                  <td class="py-3 px-4">Resume a previous conversation by ID</td>
                </tr>
              </tbody>
            </table>
          </div>
        </section>

        <hr class="border-white/[0.06] mb-20" />

        <!-- ── AI MODES ──────────────────────────────────────────── -->
        <section id="ai-modes" class="doc-section mb-20">
          <div class="flex items-center gap-3 mb-8">
            <div class="w-8 h-8 rounded-lg bg-corix-accent/10 flex items-center justify-center shrink-0">
              <Icon name="lucide:brain" class="w-4 h-4 text-corix-accent" />
            </div>
            <h1 class="text-3xl font-bold text-ctp-text">AI Modes</h1>
          </div>

          <p class="text-ctp-subtext1 leading-relaxed mb-8">
            corix ships with four AI modes, each designed for a different workflow. Switch modes at any time with the <code class="text-corix-accent">/mode</code> command inside the AI panel.
          </p>

          <!-- Default -->
          <div id="mode-default" class="scroll-mt-24 mb-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xl">?</span>
              <h2 class="text-xl font-semibold text-ctp-text">Default mode</h2>
              <span class="text-xs bg-ctp-surface0 text-ctp-subtext1 px-2 py-0.5 rounded font-mono">/mode default</span>
            </div>
            <p class="text-ctp-subtext1 leading-relaxed mb-4">
              Free-form conversational mode. Ask anything: explain a command, help write a script, look up flag options. The AI responds in the panel without touching your terminal.
            </p>
            <div class="terminal-window">
              <div class="terminal-chrome">
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
                <span class="ml-auto text-xs text-ctp-overlay0">AI panel · default</span>
              </div>
              <div class="p-4 font-mono text-sm space-y-2">
                <div><span class="text-corix-accent">you</span> <span class="text-ctp-overlay0">›</span> <span class="text-ctp-text">what does `lsof -i :5432` do?</span></div>
                <div class="text-ctp-subtext1 pl-0 leading-relaxed"><span class="text-ctp-green">ai</span> <span class="text-ctp-overlay0">›</span> Lists all processes that have an open network file on port 5432 (typically PostgreSQL). Useful for finding what's occupying a port before starting a service.</div>
              </div>
            </div>
          </div>

          <!-- Watch -->
          <div id="mode-watch" class="scroll-mt-24 mb-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xl">◉</span>
              <h2 class="text-xl font-semibold text-ctp-text">Watch mode</h2>
              <span class="text-xs bg-ctp-surface0 text-ctp-subtext1 px-2 py-0.5 rounded font-mono">/mode watch</span>
            </div>
            <p class="text-ctp-subtext1 leading-relaxed mb-4">
              corix passively monitors your terminal output. After a command finishes and output settles (800 ms of silence), the AI automatically receives the command + full output and provides a contextual summary or explanation. No input required.
            </p>
            <div class="card p-4 mb-4 flex gap-3">
              <Icon name="lucide:info" class="w-4 h-4 text-ctp-blue shrink-0 mt-0.5" />
              <p class="text-ctp-subtext1 text-sm">
                Watch mode sends output after 800 ms of silence. Long-running commands (test suites, builds) are captured when they finish naturally.
              </p>
            </div>
            <div class="terminal-window">
              <div class="terminal-chrome">
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
                <span class="ml-auto text-xs text-ctp-overlay0">AI panel · watch</span>
              </div>
              <div class="p-4 font-mono text-sm space-y-1">
                <div class="text-ctp-overlay0 text-xs mb-2">[terminal] go test ./...</div>
                <div class="text-ctp-red pl-2">FAIL: TestUserCreate (timeout 30s)</div>
                <div class="text-ctp-overlay0 mt-2 text-xs">— AI panel updates automatically —</div>
                <div class="text-ctp-green mt-2">ai › 1 test timed out. The TestUserCreate test exceeded 30 s — likely a missing mock or a real DB call blocking. Check for unresolved context deadlines.</div>
              </div>
            </div>
          </div>

          <!-- Execute -->
          <div id="mode-execute" class="scroll-mt-24 mb-10">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xl">⚡</span>
              <h2 class="text-xl font-semibold text-ctp-text">Execute mode</h2>
              <span class="text-xs bg-ctp-surface0 text-ctp-subtext1 px-2 py-0.5 rounded font-mono">/mode execute</span>
            </div>
            <p class="text-ctp-subtext1 leading-relaxed mb-4">
              After each command, the AI analyzes the output and suggests follow-up commands. Suggested commands appear as chips in the AI panel. Navigate with <kbd class="key">↑</kbd> <kbd class="key">↓</kbd>, confirm with <kbd class="key">Enter</kbd>, or dismiss with <kbd class="key">Esc</kbd>. Confirmed commands run directly in your terminal.
            </p>
            <div class="terminal-window">
              <div class="terminal-chrome">
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-red/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-yellow/80"></span>
                <span class="w-2.5 h-2.5 rounded-full bg-ctp-green/80"></span>
                <span class="ml-auto text-xs text-ctp-overlay0">AI panel · execute</span>
              </div>
              <div class="p-4 font-mono text-sm space-y-2">
                <div class="text-ctp-overlay0 text-xs">[terminal] docker compose up</div>
                <div class="text-ctp-red">Error: port 5432 already in use</div>
                <div class="border-t border-white/[0.06] mt-3 pt-3">
                  <div class="text-ctp-subtext1 text-xs mb-2">AI suggests:</div>
                  <div class="flex gap-2 flex-wrap">
                    <span class="bg-corix-accent/20 text-corix-accent border border-corix-accent/30 px-2 py-1 rounded text-xs">lsof -i :5432 | grep LISTEN</span>
                    <span class="bg-ctp-surface0 text-ctp-subtext1 border border-white/[0.08] px-2 py-1 rounded text-xs">kill $(lsof -ti :5432)</span>
                  </div>
                  <div class="text-ctp-overlay0 text-xs mt-2">↑↓ navigate · Enter run · Esc dismiss</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Debug -->
          <div id="mode-debug" class="scroll-mt-24 mb-6">
            <div class="flex items-center gap-3 mb-4">
              <span class="text-xl">🔧</span>
              <h2 class="text-xl font-semibold text-ctp-text">Debug mode</h2>
              <span class="text-xs bg-ctp-surface0 text-ctp-subtext1 px-2 py-0.5 rounded font-mono">/mode debug</span>
            </div>
            <p class="text-ctp-subtext1 leading-relaxed mb-4">
              Debug mode only activates when the terminal output contains recognizable error patterns (non-zero exit codes, stack traces, <code>Error:</code> / <code>FAIL</code> / <code>panic:</code> prefixes). When triggered, it sends the failing output to the AI and displays a diagnosis with a fix suggestion — all without any manual input.
            </p>
            <div class="card p-4 mb-4 flex gap-3">
              <Icon name="lucide:zap" class="w-4 h-4 text-ctp-peach shrink-0 mt-0.5" />
              <p class="text-ctp-subtext1 text-sm">
                Unlike Watch mode, Debug mode is <strong class="text-ctp-text">silent on success</strong>. The AI panel only updates when something goes wrong.
              </p>
            </div>
          </div>
        </section>

        <hr class="border-white/[0.06] mb-20" />

